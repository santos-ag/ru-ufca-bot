# Variáveis de ambiente para o bot
# Copie este arquivo para .env e preencha com seus valores reais

# Token do bot do Telegram (obtenha com @BotFather)
TELEGRAM_BOT_TOKEN=your_token_here

# ID do chat do administrador (obtenha com @userinfobot)
ADMIN_CHAT_ID=123456789

# Ambiente (development ou production)
ENVIRONMENT=development

# Chave de API da LLM
GOOGLE_API_KEY=....

# Modelo da LLM (opcional)
GOOGLE_MODEL=gemini-2.0-flash

# Provedor da LLM (gemini ou groq)
LLM_PROVIDER=gemini

# Chave de API da Groq (opcional)
GROQ_API_KEY=....

# Modelo da Groq (opcional)
GROQ_MODEL=llama-3.1-8b-instant

# Timezone
TIMEZONE=America/Fortaleza

# Horários de notificação (formato 24h)
LUNCH_NOTIFICATION_TIME=10:30
DINNER_NOTIFICATION_TIME=16:30
